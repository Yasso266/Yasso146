<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Yassin Store</title>

<style>
body {
  margin:0;
  font-family:Arial;
  background:#0d0d0d;
  color:#fff;
}

/* Navbar */
header {
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:15px 20px;
  background:#000;
  border-bottom:1px solid #222;
}

.logo {
  font-size:20px;
  font-weight:bold;
  letter-spacing:2px;
}

.hero {
  text-align:center;
  padding:40px 20px;
  background:linear-gradient(to right, #000, #111);
}

.hero h1 {
  font-size:28px;
}

.hero p {
  color:#aaa;
}

/* Products */
.container {
  display:grid;
  grid-template-columns:repeat(auto-fit, minmax(220px, 1fr));
  gap:20px;
  padding:20px;
}

.product {
  background:#111;
  border-radius:15px;
  overflow:hidden;
  transition:0.3s;
}

.product:hover {
  transform:scale(1.05);
}

.product img {
  width:100%;
  height:220px;
  object-fit:cover;
}

.product h2 {
  padding:10px;
  font-size:18px;
}

.price {
  padding:0 10px;
  color:#0f0;
}

button {
  width:90%;
  margin:10px;
  padding:10px;
  border:none;
  background:#fff;
  color:#000;
  border-radius:8px;
  font-weight:bold;
  cursor:pointer;
  transition:0.3s;
}

button:hover {
  background:#0f0;
}

/* Footer */
footer {
  text-align:center;
  padding:20px;
  color:#777;
  border-top:1px solid #222;
}
</style>

</head>

<body>

<header>
<div class="logo">YASSIN</div>
</header>

<div class="hero">
<h1>🔥 New Collection 🔥</h1>
<p>أفضل الشوزات بأعلى جودة</p>
</div>

<div class="container">

<div class="product">
<img src="https://i.imgur.com/8Km9tLL.jpg">
<h2>شوز أبيض مودرن</h2>
<p class="price">650 جنيه</p>
<a href="https://wa.me/201XXXXXXXXX">
<button>اطلب الآن</button>
</a>
</div>

<div class="product">
<img src="https://i.imgur.com/3ZQ3Z6G.jpg">
<h2>شوز أسود فاخر</h2>
<p class="price">700 جنيه</p>
<a href="https://wa.me/201XXXXXXXXX">
<button>اطلب الآن</button>
</a>
</div>

</div>

<footer>
© 2026 Yassin Store
</footer>

</body>
</html>
